---
---
<section class="relative flex items-center pt-24 pb-4 px-6 overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-gradient-to-br from-indigo-200/30 to-purple-200/30 dark:from-indigo-900/15 dark:to-purple-900/15 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-gradient-to-tr from-pink-200/20 to-orange-200/20 dark:from-pink-900/10 dark:to-orange-900/10 rounded-full blur-3xl"></div>
  </div>
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#8882_1px,transparent_1px),linear-gradient(to_bottom,#8882_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_60%,transparent_100%)] pointer-events-none opacity-[0.12] dark:opacity-[0.05]"></div>

  <div class="relative max-w-5xl mx-auto w-full">
    <div class="max-w-2xl">
      <div class="animate stagger-1 font-mono text-sm text-stone-400 dark:text-stone-500 mb-3">
        <span class="text-emerald-600 dark:text-emerald-400">~</span> <span class="text-stone-500 dark:text-stone-400">$</span> whoami
      </div>
      <h1 class="animate stagger-2 font-mono">
        <span class="text-stone-500 dark:text-stone-400 text-lg">Hi, I'm </span>
        <span class="block text-4xl sm:text-5xl font-bold tracking-tight text-stone-900 dark:text-stone-50 leading-[1.1] mt-1">
          <span id="typed-name"></span><span id="cursor" class="inline-block w-[3px] h-[0.9em] bg-stone-900 dark:bg-stone-50 ml-1 align-middle animate-blink"></span>
        </span>
      </h1>
      <p class="animate stagger-3 mt-5 text-base font-mono text-stone-500 dark:text-stone-400 leading-relaxed">
        I'm a 3rd year <span class="font-semibold text-stone-800 dark:text-stone-200">Computer Engineering</span> student at <span class="font-semibold text-stone-800 dark:text-stone-200">UBC</span>.
        I love building things across the stack — from web apps to compilers to low-level systems.
      </p>
      <p class="animate stagger-4 mt-4 text-sm text-stone-400 dark:text-stone-500 leading-relaxed">
        Outside of code you'll find me in the gym or on the basketball court.
      </p>
    </div>
  </div>
</section>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .animate-blink {
    animation: blink 1s step-end infinite;
  }
</style>

<script>
  const name = 'Jason Mac';
  const el = document.getElementById('typed-name')!;
  const cursor = document.getElementById('cursor')!;
  let i = 0;
  cursor.style.animation = 'none';
  cursor.style.opacity = '1';
  setTimeout(() => {
    const interval = setInterval(() => {
      el.textContent = name.slice(0, ++i);
      if (i === name.length) {
        clearInterval(interval);
        cursor.style.animation = '';
      }
    }, 75);
  }, 600);
</script>
