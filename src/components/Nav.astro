---
import ThemeToggle from './ThemeToggle.astro';
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="mx-auto max-w-5xl px-6">
    <div class="flex h-16 items-center justify-between">
      <a id="nav-brand" href="/" class="group flex items-center gap-2 opacity-0 -translate-y-2 pointer-events-none transition-all duration-300">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-stone-900 dark:bg-stone-100 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3">
          <span class="text-xs font-bold text-white dark:text-stone-900 font-mono">JM</span>
        </div>
        <div class="hidden sm:block">
          <span class="text-sm font-semibold tracking-tight text-stone-700 dark:text-stone-300 block leading-tight">
            Jason Mac
          </span>
          <span class="text-xs text-stone-400 dark:text-stone-500 block leading-tight">
            Computer Engineering @ UBC
          </span>
        </div>
      </a>

      <div class="flex items-center gap-1">
        <a
          href="https://github.com/jason-mac"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="group p-2.5 rounded-xl hover:bg-stone-100 dark:hover:bg-stone-800/80 transition-all duration-300"
        >
          <svg class="w-[18px] h-[18px] transition-transform duration-300 group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>

        <a
          href="mailto:jasonvanmac@gmail.com"
          aria-label="Email"
          class="group p-2.5 rounded-xl hover:bg-stone-100 dark:hover:bg-stone-800/80 transition-all duration-300"
        >
          <svg class="w-[18px] h-[18px] transition-transform duration-300 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </a>

        <a
          href="/resume.pdf"
          target="_blank"
          aria-label="Resume"
          class="group p-2.5 rounded-xl hover:bg-stone-100 dark:hover:bg-stone-800/80 transition-all duration-300"
        >
          <svg class="w-[18px] h-[18px] transition-transform duration-300 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m.75 12l3 3m0 0l3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </a>

        <div class="w-px h-5 bg-stone-200 dark:bg-stone-700 mx-1"></div>

        <ThemeToggle />
      </div>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar')!;
  const brand = document.getElementById('nav-brand')!;
  const updateNav = () => {
    const scrolled = window.scrollY > 200;
    if (scrolled) {
      navbar.classList.add('bg-white/80', 'dark:bg-stone-950/80', 'backdrop-blur-xl', 'border-b', 'border-stone-200/30', 'dark:border-stone-800/30');
      brand.classList.remove('opacity-0', '-translate-y-2', 'pointer-events-none');
      brand.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
    } else {
      navbar.classList.remove('bg-white/80', 'dark:bg-stone-950/80', 'backdrop-blur-xl', 'border-b', 'border-stone-200/30', 'dark:border-stone-800/30');
      brand.classList.add('opacity-0', '-translate-y-2', 'pointer-events-none');
      brand.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
    }
  };
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();
</script>
