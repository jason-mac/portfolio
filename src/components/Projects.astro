---
const folderPath = 'M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z';
const arrowPath = 'M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25';

const projects = [
  {
    name: 'Real-Time Chat Application',
    description: 'A full-stack real-time chat application with RESTful backend, JWT authentication, WebSocket messaging, and a React frontend, deployed on Render and Vercel.',
    tags: ['Rust', 'Axum', 'React', 'TypeScript', 'PostgreSQL'],
    url: 'https://github.com/jason-mac/chat-app',
  },
  {
    name: 'UBC Course Planner',
    description: 'A cross platform application for planning and organizing UBC courses across semesters with an interactive UI using drag and drop mechanisms.',
    tags: ['MAUI', 'TypeScript', 'C#', '.NET'],
    url: 'https://github.com/jason-mac/course-planner',
  },
  {
    name: 'Lua Bytecode Compiler & Virtual Machine',
    description: 'A bytecode compiler and stack-based virtual machine for a subset of Lua 5.1, built in C++. Implements a full pipeline from source to execution, including a lexer, recursive descent parser, and a VM runtime with closures, lexical scoping, and first-class functions.',
    tags: ['C++', 'Lua'],
    url: 'https://github.com/jason-mac/lua-vm',
  },
  {
    name: 'Tron Light Cycle Game',
    description: 'A multiplayer Tron light cycle game built from scratch running on a Risc-V cpu softcore on FPGA.',
    tags: ['C', 'Risc-V', 'Alterra FPGA'],
    url: 'https://github.com/jason-mac/tron',
  },
];

const tagColors = {
  Rust: 'bg-orange-100 text-orange-700 dark:bg-orange-500/10 dark:text-orange-300',
  Axum: 'bg-orange-100 text-orange-700 dark:bg-orange-500/10 dark:text-orange-300',
  React: 'bg-cyan-100 text-cyan-700 dark:bg-cyan-500/10 dark:text-cyan-300',
  TypeScript: 'bg-blue-100 text-blue-700 dark:bg-blue-500/10 dark:text-blue-300',
  PostgreSQL: 'bg-sky-100 text-sky-700 dark:bg-sky-500/10 dark:text-sky-300',
  MAUI: 'bg-purple-100 text-purple-700 dark:bg-purple-500/10 dark:text-purple-300',
  CSharp: 'bg-purple-100 text-purple-700 dark:bg-purple-500/10 dark:text-purple-300',
  NET: 'bg-indigo-100 text-indigo-700 dark:bg-indigo-500/10 dark:text-indigo-300',
  CPlusPlus: 'bg-blue-100 text-blue-700 dark:bg-blue-500/10 dark:text-blue-300',
  Lua: 'bg-stone-100 text-stone-700 dark:bg-stone-500/10 dark:text-stone-300',
  C: 'bg-stone-100 text-stone-700 dark:bg-stone-500/10 dark:text-stone-300',
  RiscV: 'bg-green-100 text-green-700 dark:bg-green-500/10 dark:text-green-300',
  AlterraFPGA: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-500/10 dark:text-yellow-300',
  Lua: 'bg-indigo-100 text-indigo-700 dark:bg-indigo-500/10 dark:text-indigo-300',
};

const tagKeyMap = {
  'C#': 'CSharp',
  '.NET': 'NET',
  'C++': 'CPlusPlus',
  'Risc-V': 'RiscV',
  'Alterra FPGA': 'AlterraFPGA',
};

const defaultTagClass = 'bg-stone-100 text-stone-600 dark:bg-stone-500/10 dark:text-stone-300';

const enriched = projects.map((p) => ({
  ...p,
  tagClasses: p.tags.map((t) => tagColors[tagKeyMap[t] || t] || defaultTagClass),
}));
---

<section id="projects" class="py-6 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="bash-prompt animate"><span class="prompt-symbol">~</span> <span class="prompt-dollar">$</span> ls ~/projects</div>
    <h2 class="section-title animate">Projects</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {enriched.map((project) => (
        <a href={project.url} target="_blank" rel="noopener noreferrer" class="animate group block rounded-2xl border border-stone-200/60 dark:border-stone-800/60 bg-white dark:bg-stone-900/60 p-5 card-hover">
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-stone-400 dark:text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={folderPath} />
              </svg>
              <h3 class="text-sm font-semibold text-stone-900 dark:text-stone-50 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors duration-300">
                {project.name}
              </h3>
            </div>
            <svg class="w-4 h-4 text-stone-300 dark:text-stone-600 group-hover:text-stone-500 dark:group-hover:text-stone-400 transition-all duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={arrowPath} />
            </svg>
          </div>
          <p class="text-sm text-stone-500 dark:text-stone-400 leading-relaxed mb-3">
            {project.description}
          </p>
          <div class="flex flex-wrap gap-1.5 mt-3">
            {project.tags.map((tag, ti) => (
              <span class={'px-2 py-0.5 rounded-md text-xs font-semibold ' + project.tagClasses[ti]}>
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
